{
  "name": "@tuyau/superjson",
  "type": "module",
  "version": "1.0.0",
  "description": "SuperJSON plugin for Tuyau and AdonisJS",
  "author": "Julien Ripouteau <julien@ripouteau.com>",
  "license": "MIT",
  "homepage": "https://github.com/Julien-R44/tuyau#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Julien-R44/tuyau.git",
    "directory": "packages/superjson"
  },
  "bugs": {
    "url": "https://github.com/Julien-R44/tuyau/issues"
  },
  "keywords": [
    "adonisjs",
    "typescript",
    "superjson",
    "serialization",
    "tuyau"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/src/types.js",
    "./superjson_middleware": "./build/middleware/superjson_middleware.js",
    "./plugin": "./build/client/plugin.js"
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "del-cli build",
    "typecheck": "tsc --noEmit",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts --force-exit",
    "test": "c8 npm run quick:test",
    "prebuild": "npm run clean",
    "build": "pnpm clean && tsup-node",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0-next.10"
  },
  "dependencies": {
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.1",
    "@adonisjs/core": "^7.0.1",
    "@tuyau/core": "workspace:*",
    "nock": "^14.0.11"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./middleware/superjson_middleware.ts",
      "./client/plugin.ts"
    ],
    "outDir": "./build",
    "clean": false,
    "format": "esm",
    "dts": true,
    "target": "esnext"
  }
}
