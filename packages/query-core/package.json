{
  "name": "@tuyau/query-core",
  "type": "module",
  "version": "1.1.0",
  "description": "Shared utilities for Tuyau Tanstack Query integrations",
  "author": "Julien Ripouteau <julien@ripouteau.com>",
  "license": "MIT",
  "homepage": "https://github.com/Julien-R44/tuyau#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Julien-R44/tuyau.git",
    "directory": "packages/query-core"
  },
  "bugs": {
    "url": "https://github.com/Julien-R44/tuyau/issues"
  },
  "keywords": [
    "adonisjs",
    "typescript",
    "typesafe",
    "tanstack-query",
    "tuyau"
  ],
  "exports": {
    ".": "./build/index.js",
    "./test-helpers": "./tests/helpers/index.ts"
  },
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "build": "tsup-node",
    "test": "pnpm quick:test",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts --force-exit",
    "checks": "pnpm lint && pnpm typecheck"
  },
  "peerDependencies": {
    "@tanstack/query-core": "^5.74.7",
    "@tuyau/core": "^1.0.0-beta.9"
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.96.2",
    "@tuyau/core": "workspace:*"
  },
  "tsup": {
    "entry": [
      "./src/index.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": true,
    "target": "esnext"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest",
    "exports": {
      ".": "./build/index.js"
    }
  }
}
