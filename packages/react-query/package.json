{
  "name": "@tuyau/react-query",
  "type": "module",
  "version": "1.0.0-beta.1",
  "description": "React Query plugin for Tuyau",
  "author": "Julien Ripouteau <julien@ripouteau.com>",
  "license": "ISC",
  "keywords": [],
  "exports": {
    ".": "./build/index.js"
  },
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsup-node",
    "test": "pnpm quick:test",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts --force-exit",
    "checks": "pnpm lint && pnpm typecheck"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.74.7",
    "@tuyau/core": "1.0.0-beta.2"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.0.0-next.13",
    "@faker-js/faker": "^10.1.0",
    "@happy-dom/global-registrator": "^20.0.11",
    "@tanstack/react-query": "^5.90.12",
    "@testing-library/react": "^16.3.0",
    "@tuyau/core": "workspace:*",
    "@types/react": "^19.2.7",
    "@vinejs/vine": "^4.1.0",
    "react": "^19.2.1"
  },
  "tsup": {
    "entry": [
      "./src/index.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": true,
    "target": "esnext"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  }
}
