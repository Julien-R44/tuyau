{
  "name": "@tuyau/react-query",
  "type": "module",
  "version": "1.0.0",
  "description": "Tanstack Query integration for Tuyau",
  "author": "Julien Ripouteau <julien@ripouteau.com>",
  "license": "MIT",
  "homepage": "https://github.com/Julien-R44/tuyau#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Julien-R44/tuyau.git",
    "directory": "packages/react-query"
  },
  "bugs": {
    "url": "https://github.com/Julien-R44/tuyau/issues"
  },
  "keywords": [
    "adonisjs",
    "typescript",
    "typesafe",
    "react-query",
    "tanstack-query",
    "tuyau"
  ],
  "exports": {
    ".": "./build/index.js"
  },
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "build": "tsup-node",
    "test": "pnpm quick:test",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts --force-exit",
    "checks": "pnpm lint && pnpm typecheck"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.74.7",
    "@tuyau/core": "^1.0.0-beta.9"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.0.1",
    "@faker-js/faker": "^10.3.0",
    "@happy-dom/global-registrator": "^20.8.3",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/react": "^16.3.2",
    "@tuyau/core": "workspace:*",
    "@types/react": "^19.2.14",
    "@vinejs/vine": "^4.3.0",
    "react": "^19.2.4"
  },
  "tsup": {
    "entry": [
      "./src/index.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": true,
    "target": "esnext"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
