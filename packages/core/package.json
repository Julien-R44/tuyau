{
  "name": "@tuyau/core",
  "type": "module",
  "version": "1.0.0-beta.9",
  "description": "e2e client for AdonisJS",
  "author": "Julien Ripouteau <julien@ripouteau.com>",
  "license": "MIT",
  "keywords": [
    "adonisjs",
    "e2e",
    "client"
  ],
  "exports": {
    "./client": "./build/client/index.js",
    "./types": "./build/client/types/index.js",
    "./commands": "./build/commands/main.js",
    "./hooks": "./build/backend/generate_registry.js"
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "del-cli build",
    "copy:templates": "copyfiles --up 1 \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts --force-exit",
    "test": "c8 npm run quick:test",
    "index:commands": "adonis-kit index build/commands",
    "prebuild": "npm run clean",
    "build": "pnpm clean && tsup-node && pnpm copy:templates && pnpm index:commands",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0-next.27",
    "@adonisjs/core": "^7.0.0-next.16"
  },
  "dependencies": {
    "ky": "^1.14.1",
    "object-to-formdata": "^4.5.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0-next.27",
    "@adonisjs/core": "^7.0.0-next.16",
    "@adonisjs/http-server": "^8.0.0-next.16",
    "@faker-js/faker": "^10.1.0",
    "@poppinss/ts-exec": "^1.4.1",
    "@types/node": "^25.0.3",
    "@typescript/analyze-trace": "^0.10.1",
    "@vinejs/vine": "^4.2.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "tsup": {
    "entry": [
      "./src/backend/generate_registry.ts",
      "./src/client/index.ts",
      "./src/client/types/index.ts"
    ],
    "outDir": "./build",
    "clean": false,
    "format": "esm",
    "dts": true,
    "target": "esnext"
  }
}
